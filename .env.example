# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# JWT secret used to sign Supabase-compatible JWTs.
# Get from Supabase: Project Settings -> API -> JWT Settings -> JWT Secret.
# (Day 2 change: this MUST equal the Supabase JWT secret so RLS policies recognise our session.)
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# Session secret (separate, for day-1 only; day 2 collapses both into SUPABASE_JWT_SECRET).
# openssl rand -base64 48
SESSION_SECRET=replace-with-48-random-bytes

# --- Email + AI ---
RESEND_API_KEY=re_xxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxx

# --- Modes ---
# Set to "true" only on the demo Fly app (broker-demo). Never on a customer app.
NEXT_PUBLIC_DEMO_MODE=false

# --- Optional ---
NEXT_PUBLIC_APP_URL=https://broker-demo.fly.dev
